# Змінні середовища (Cloudflare → Settings → Environment variables). У код НЕ кладуться.
TG_BOT_TOKEN=123456789:AA...ваш_токен_від_BotFather...
TG_CHAT_ID=-1001234567890

# KV-біндінг (Settings → Functions → KV namespace bindings), назва змінної: RECORDS
# Потрібен для збереження записок на 7 днів і сторінки-памʼятки. Значення тут не пишеться —
# у Cloudflare створюється KV namespace і привʼязується під іменем RECORDS.
