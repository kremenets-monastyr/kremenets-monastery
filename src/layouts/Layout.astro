---
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-sans/700.css';
import '@fontsource/ibm-plex-sans/400-italic.css';
import '@fontsource/monomakh/400.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title = 'Свято-Богоявленський Кременецький монастир', description = 'Онлайн-подача церковних записок за здоровя та за упокій.' } = Astro.props;
---
<!doctype html>
<html lang="uk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/logo.png" />
</head>
<body>
  <script is:inline>
    (function(){
      try{ var z=localStorage.getItem('kr_zoom')||'1'; document.documentElement.setAttribute('data-zoom',z); }catch(e){}
      document.addEventListener('DOMContentLoaded',function(){
        var box=document.getElementById('krZoom'); if(!box)return;
        var cur=document.documentElement.getAttribute('data-zoom')||'1';
        function paint(v){ box.querySelectorAll('button').forEach(function(b){ b.classList.toggle('on', b.dataset.z===v); }); }
        paint(cur);
        box.addEventListener('click',function(e){
          var b=e.target.closest('button'); if(!b)return;
          var v=b.dataset.z;
          document.documentElement.setAttribute('data-zoom',v);
          try{ localStorage.setItem('kr_zoom',v); }catch(err){}
          paint(v);
        });
      });
      // Шапка: тінь при прокрутці; на мобільному ховається при скролі вниз і зʼявляється при скролі вгору
      document.addEventListener('DOMContentLoaded',function(){
        var h=document.querySelector('.xhead'); if(!h)return;
        var last=window.pageYOffset||0, ticking=false;
        function upd(){
          var y=window.pageYOffset||0;
          h.classList.toggle('scrolled', y>4);
          if(window.innerWidth<=900){
            if(y>last+6 && y>120){ h.classList.add('hide'); }
            else if(y<last-6 || y<=60){ h.classList.remove('hide'); }
          } else { h.classList.remove('hide'); }
          last=y; ticking=false;
        }
        window.addEventListener('scroll',function(){ if(!ticking){ ticking=true; requestAnimationFrame(upd); } },{passive:true});
        window.addEventListener('resize',function(){ if(window.innerWidth>900) h.classList.remove('hide'); });
        upd();
      });
    })();
  </script>
  <Header />
  <slot />
  <Footer />
</body>
</html>
